{
    "name": "BackupGen_Service",
    "esdl_type": "GasProducer",
    "description": "Simulates backup generation with spin-up delay.",
    "relevant_links": [],
    "calculations": [
        {
            "name": "real_time_backup",
            "time_period_in_seconds" : 900,
            "offset_in_seconds" : 0,
            "description": "Handles diesel generator output based on EMS requests.",
            "inputs": [
                {
                    "name": "Backup_requested_power",
                    "esdl_type": "ElectricityNetwork",
                    "data_type": "DOUBLE",
                    "description": "Command to turn on or increase load.",
                    "unit": "W"
                }
            ],
            "outputs": [
                {
                    "name": "Backup_supplied_power",
                    "data_type": "DOUBLE",
                    "description": "Actual power supplied.",
                    "unit": "W"
                },
                {
                    "name": "available_max_power",
                    "data_type": "DOUBLE",
                    "description": "Maximum capacity of the generator.",
                    "unit": "W"
                }
            ]
        }
    ]
}